        "any": [
          {
            "flag": "owns_ranking_prod",
            "negate": false
          },
          {
            "flag": "owns_retrieval_prod",
            "negate": false
          }
        ]
      }
    },
    "gates": [
      {
        "when": {
          "flag": "primarily_adjacent",
          "negate": false
        },
        "multiplier": 0.55
      },
      {
        "when": {
          "flag": "observer_not_owner",
          "negate": false
        },
        "multiplier": 0.65
      },
      {
        "when": {
          "flag": "manager_not_builder",
          "negate": false
        },
        "multiplier": 0.35
      },
      {
        "when": {
          "flag": "is_hobbyist_or_self_learner",
          "negate": false
        },
        "multiplier": 0.5
      },
      {
        "when": {
          "all": [
            {
              "any": [
                {
                  "flag": "cv_dominant",
                  "negate": false
                },
                {
                  "flag": "speech_dominant",
                  "negate": false
                },
                {
                  "flag": "robotics_dominant",
                  "negate": false
                }
              ]
            },
            {
              "not": {
                "flag": "nlp_ir_significant",
                "negate": false
              }
            }
          ]
        },
        "multiplier": 0.25,
        "id": "domain_gate"
      }
    ],
    "clamp": [
      0.0,
      1.0
    ]
  },
  "skill_booster": {
    "when": {
      "metric": "career_substance",
      "op": ">=",
      "value": 0.6
    },
    "per_skill": 0.02,
    "max": 0.06,
    "count_feature": "num_qualifying_unevidenced_skills",
    "credit_rule": "count num_qualifying_unevidenced_skills, bonus = min(max, per_skill * count). disqualified skills give zero (not a penalty).",
