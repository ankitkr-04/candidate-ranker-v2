    "PharmEasy": "2015-04",
    "upGrad": "2015-03",
    "Wysa": "2015-11",
    "Locobuzz": "2015-08",
    "Yellow.ai": "2016-06",
    "Verloop.io": "2016-10",
    "Niramai": "2016-07",
    "Aganitha": "2016-01",
    "Observe.AI": "2017-11",
    "Saarthi.ai": "2017-09",
    "CRED": "2018-04",
    "Glance": "2019-09",
    "Rephrase.ai": "2019-02",
    "Sarvam AI": "2023-07",
    "Krutrim": "2023-04"
  },
  "params": {
    "overrun_slack_months": 18.0,
    "seniority_min_rank": 3,
    "experience_span_buffer_years": 5.0,
    "anachronism_buffer_months": 3.0,
    "anachronism_grace_years": 0.75,
    "anomaly_buffer_months": 12.0,
    "company_predates_buffer_months": 3.0
  },
  "seniority_ladder": {
    "default": 2,
    "tiers": [
      {
        "keywords": [
          "intern"
        ],
        "rank": 0
      },
      {
        "keywords": [
          "junior",
          "jr",
          "associate",
          "trainee"
        ],
        "rank": 1
      },
      {
        "keywords": [
          "senior",
          "sr",
          "lead",
          "principal",
          "staff"
        ],
        "rank": 3
      },
      {
        "keywords": [
          "manager",
          "head",
          "director",
          "vp",
          "chief",
          "cto"
        ],
        "rank": 4
      }
    ]
  },
  "features": {
    "flags": [
      "end_before_start",
      "career_months_overrun",
      "role_months_overrun",
      "current_role_date_conflict",
      "senior_title_pre_graduation",
      "experience_exceeds_career_span"
    ],
    "metrics": [
      "num_education_overlaps",
      "num_skill_anomalies",
      "num_proficiency_anomalies",
      "num_skill_anachronisms",
      "skill_anachronism_years",
      "years_predating_company"
    ]
  },
  "penalties": [
    {
      "type": "conditional",
      "id": "end_before_start_penalty",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "flag": "end_before_start",
            "negate": false
          },
          "value": 0.4
        }
      ]
    },
    {
      "type": "conditional",
      "id": "career_months_overrun_penalty",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "flag": "career_months_overrun",
            "negate": false
          },
          "value": 0.9
        }
      ]
    },
    {
      "type": "conditional",
      "id": "role_months_overrun_penalty",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "flag": "role_months_overrun",
            "negate": false
          },
          "value": 0.85
        }
      ]
    },
    {
      "type": "conditional",
      "id": "current_role_date_conflict_penalty",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "flag": "current_role_date_conflict",
            "negate": false
          },
          "value": 0.85
        }
      ]
    },
    {
      "type": "conditional",
      "id": "experience_span_penalty",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "flag": "experience_exceeds_career_span",
            "negate": false
          },
          "value": 0.1
        }
      ]
    },
    {
      "type": "decay",
      "id": "education_overlap_penalty",
      "feature": "num_education_overlaps",
      "base": 0.98,
      "floor": 0.92
    },
    {
      "type": "decay",
      "id": "skill_anomaly_penalty",
      "feature": "num_skill_anomalies",
      "base": 0.985,
      "floor": 0.93
    },
    {
      "type": "decay",
      "id": "proficiency_anomaly_penalty",
      "feature": "num_proficiency_anomalies",
      "base": 0.55,
      "floor": 0.12
    },
    {
      "type": "decay",
      "id": "skill_anachronism_magnitude_penalty",
      "feature": "skill_anachronism_years",
      "base": 0.85,
      "floor": 0.2
    },
    {
      "type": "curve",
      "id": "skill_anachronism_count_penalty",
      "feature": "num_skill_anachronisms",
      "direction": "max",
      "bands": [
        {
          "at": 1.0,
          "value": 1.0
        },
        {
          "at": 2.0,
          "value": 0.82
        },
        {
          "at": 3.0,
          "value": 0.55
        },
        {
          "at": 4.0,
          "value": 0.35
        },
        {
          "value": 0.2
        }
      ]
    },
    {
      "type": "curve",
      "id": "company_predates_penalty",
      "feature": "years_predating_company",
      "direction": "max",
      "bands": [
        {
          "at": 0.0,
          "value": 1.0
        },
        {
          "at": 1.0,
          "value": 0.97
        },
        {
          "at": 2.0,
          "value": 0.6
        },
        {
          "at": 3.0,
          "value": 0.35
        },
        {
          "at": 4.0,
          "value": 0.2
        },
        {
          "value": 0.18
        }
      ]
    },
    {
      "type": "conditional",
      "id": "seniority_before_graduation_penalty",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "flag": "senior_title_pre_graduation",
            "negate": false
          },
          "value": 0.85
        }
      ]
    }
  ]
}