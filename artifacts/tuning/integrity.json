    "Flipkart": "2007-10",
    "InMobi": "2007-01",
    "Zoho": "1996-03",
    "Dream11": "2008-04",
    "PolicyBazaar": "2008-06",
    "Zomato": "2008-07",
    "Ola": "2010-12",
    "Paytm": "2010-08",
    "Freshworks": "2010-10",
    "BYJU'S": "2011-11",
    "Vedantu": "2011-11",
    "Nykaa": "2012-04",
    "Haptik": "2013-08",
    "Mad Street Den": "2013-11",
    "Swiggy": "2014-08",
    "Razorpay": "2014-12",
    "Meesho": "2015-12",
    "PhonePe": "2015-12",
