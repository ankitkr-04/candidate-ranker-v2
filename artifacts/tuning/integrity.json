{
  "version": "1.0",
  "description": "Job-agnostic profile-integrity penalties. Each flags data that is implausible for any genuine candidate (inconsistent dates, a skill used longer than the person has worked or longer than the tool has existed, a senior title dated before the first degree finished). Applied as small multiplicative penalties that compound into a ranking gradient -- no single hard cut.",
  "tool_eras": {
    "prompt engineering": 2020,
    "rag": 2020,
    "langchain": 2022,
    "llamaindex": 2022,
    "chatgpt": 2022,
    "llms": 2019,
    "llm fine-tuning": 2021,
    "lora": 2021,
    "qlora": 2023,
    "peft": 2022,
    "vector database": 2019,
    "vector search": 2019,
    "weaviate": 2019,
    "pinecone": 2019,
    "qdrant": 2021,
    "milvus": 2019,
    "sentence transformers": 2019,
    "semantic search": 2019,
    "hugging face transformers": 2019,
    "faiss": 2017,
    "mlflow": 2018,
    "haystack": 2019,
    "bentoml": 2019,
    "kubeflow": 2017,
    "diffusion models": 2021,
    "pgvector": 2021,
    "opensearch": 2021
  },
  "company_founding": {
    "TCS": 1968,
    "Wipro": 1945,
    "Infosys": 1981,
    "HCL": 1976,
    "Capgemini": 1967,
    "Accenture": 1989,
    "Cognizant": 1994,
    "Tech Mahindra": 1986,
    "Mindtree": 1999,
    "Mphasis": 1998,
    "Genpact AI": 1997,
    "Apple": 1976,
    "Microsoft": 1975,
    "Google": 1998,
    "Amazon": 1994,
    "Meta": 2004,
    "Netflix": 1997,
    "Adobe": 1982,
    "Salesforce": 1999,
    "LinkedIn": 2003,
    "Uber": 2009,
    "Flipkart": 2007,
    "InMobi": 2007,
    "Zoho": 1996,
    "Dream11": 2008,
    "PolicyBazaar": 2008,
    "Zomato": 2008,
    "Ola": 2010,
    "Paytm": 2010,
    "Freshworks": 2010,
    "BYJU'S": 2011,
    "Vedantu": 2011,
    "Nykaa": 2012,
    "Haptik": 2013,
    "Mad Street Den": 2013,
    "Swiggy": 2014,
    "Razorpay": 2014,
    "Meesho": 2015,
    "PhonePe": 2015,
    "Unacademy": 2015,
    "PharmEasy": 2015,
    "upGrad": 2015,
    "Wysa": 2015,
    "Locobuzz": 2015,
    "Yellow.ai": 2016,
    "Verloop.io": 2016,
    "Niramai": 2016,
    "Aganitha": 2016,
    "Observe.AI": 2017,
    "Saarthi.ai": 2017,
    "CRED": 2018,
    "Glance": 2019,
    "Rephrase.ai": 2019,
    "Sarvam AI": 2023,
    "Krutrim": 2023
  },
  "params": {
    "overrun_slack_months": 18.0,
    "seniority_min_rank": 3,
    "experience_span_buffer_years": 5.0
  },
  "seniority_ladder": {
    "default": 2,
    "tiers": [
      {
        "keywords": [
          "intern"
        ],
        "rank": 0
      },
      {
        "keywords": [
          "junior",
          "jr",
          "associate",
          "trainee"
        ],
        "rank": 1
      },
      {
        "keywords": [
          "senior",
          "sr",
          "lead",
          "principal",
          "staff"
        ],
        "rank": 3
      },
      {
        "keywords": [
          "manager",
          "head",
          "director",
          "vp",
          "chief",
          "cto"
        ],
        "rank": 4
      }
    ]
  },
  "features": {
    "flags": [
      "end_before_start",
      "career_months_overrun",
      "role_months_overrun",
      "current_role_date_conflict",
      "senior_title_pre_graduation",
      "experience_exceeds_career_span"
    ],
    "metrics": [
      "num_education_overlaps",
      "num_skill_anomalies",
      "num_proficiency_anomalies",
      "num_skill_anachronisms",
      "years_predating_company"
    ]
  },
  "penalties": [
    {
      "type": "conditional",
      "id": "end_before_start_penalty",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "flag": "end_before_start",
            "negate": false
          },
          "value": 0.4
        }
      ]
    },
    {
      "type": "conditional",
      "id": "career_months_overrun_penalty",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "flag": "career_months_overrun",
            "negate": false
          },
          "value": 0.9
        }
      ]
    },
    {
      "type": "conditional",
      "id": "role_months_overrun_penalty",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "flag": "role_months_overrun",
            "negate": false
          },
          "value": 0.85
        }
      ]
    },
    {
      "type": "conditional",
      "id": "current_role_date_conflict_penalty",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "flag": "current_role_date_conflict",
            "negate": false
          },
          "value": 0.85
        }
      ]
    },
    {
      "type": "conditional",
      "id": "experience_span_penalty",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "flag": "experience_exceeds_career_span",
            "negate": false
          },
          "value": 0.1
        }
      ]
    },
    {
      "type": "decay",
      "id": "education_overlap_penalty",
      "feature": "num_education_overlaps",
      "base": 0.98,
      "floor": 0.92
    },
    {
      "type": "decay",
      "id": "skill_anomaly_penalty",
      "feature": "num_skill_anomalies",
      "base": 0.985,
      "floor": 0.93
    },
    {
      "type": "decay",
      "id": "proficiency_anomaly_penalty",
      "feature": "num_proficiency_anomalies",
      "base": 0.55,
      "floor": 0.12
    },
    {
      "type": "curve",
      "id": "skill_anachronism_penalty",
      "feature": "num_skill_anachronisms",
      "direction": "max",
      "bands": [
        {
          "at": 0.0,
          "value": 1.0
        },
        {
          "at": 1.0,
          "value": 0.97
        },
        {
          "at": 2.0,
          "value": 0.82
        },
        {
          "at": 3.0,
          "value": 0.55
        },
        {
          "at": 4.0,
          "value": 0.33
        },
        {
          "value": 0.2
        }
      ]
    },
    {
      "type": "curve",
      "id": "company_predates_penalty",
      "feature": "years_predating_company",
      "direction": "max",
      "bands": [
        {
          "at": 0.0,
          "value": 1.0
        },
        {
          "at": 1.0,
          "value": 0.97
        },
        {
          "at": 2.0,
          "value": 0.6
        },
        {
          "at": 3.0,
          "value": 0.35
        },
        {
          "at": 4.0,
          "value": 0.2
        },
        {
          "value": 0.18
        }
      ]
    },
    {
      "type": "conditional",
      "id": "seniority_before_graduation_penalty",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "flag": "senior_title_pre_graduation",
            "negate": false
          },
          "value": 0.85
        }
      ]
    }
  ]
}