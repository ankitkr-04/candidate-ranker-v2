    "semantic search": "2019",
    "hugging face transformers": "2019-07",
    "faiss": "2017-03",
    "mlflow": "2018-06",
    "haystack": "2019-11",
    "bentoml": "2019-03",
    "kubeflow": "2017-12",
    "diffusion models": "2021-12",
    "pgvector": "2021-08",
    "opensearch": "2021-07"
  },
  "company_founding": {
