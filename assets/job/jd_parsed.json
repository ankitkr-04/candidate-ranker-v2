  "slm_questions": {
    "input_scope": "career_history only (titles, companies, descriptions, is_current). No education/skills/location/signals.",
    "extraction_order": "emit subject_of_primary_work and a 1-line evidence span first, then booleans. Never alphabetize the schema.",
    "ask": [
      {
        "id": "subject_of_primary_work",
        "type": "string",
        "q": "In the candidate's most ML-relevant role, who performed the core ML/retrieval/ranking work — the candidate personally, their team/colleagues, or a team they managed? Quote the phrase that tells you."
      },
      {
        "id": "owns_retrieval_prod",
        "q": "Did the candidate personally build or own a production embeddings-based retrieval system serving real users?"
      },
      {
        "id": "vector_db_prod",
        "q": "Did the candidate personally operate a vector DB or hybrid-search infrastructure in production (Pinecone/Weaviate/Qdrant/Milvus/OpenSearch/Elasticsearch/FAISS or similar)?"
      },
      {
        "id": "owns_eval_framework",
        "q": "Did the candidate design an evaluation framework for a ranking/retrieval system (NDCG/MRR/MAP, offline-to-online correlation, or A/B-test interpretation)?"
      },
      {
        "id": "strong_python_prod",
