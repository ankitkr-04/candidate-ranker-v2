  "slm_questions": {
    "input_scope": "career_history only (titles, companies, descriptions, is_current). No education/skills/location/signals.",
    "extraction_order": "emit subject_of_primary_work and a 1-line evidence span first, then booleans. Never alphabetize the schema. Judge domain/topic booleans by the product domain explicitly named in the description -- never infer a domain from generic words like 'match', 'relevance', 'ranking', or 'recommendation'. Default every boolean to false unless the evidence span you quoted directly supports it.",
    "ask": [
      {
        "id": "subject_of_primary_work",
        "type": "string",
        "q": "In the candidate's most ML-relevant role, who performed the core ML/retrieval/ranking work? Answer with exactly one of: 'candidate personally', 'team/colleagues', or 'managed a team', then quote the phrase that shows it. Output only that answer -- never restate or echo this question."
      },
      {
        "id": "owns_retrieval_prod",
        "q": "Did the candidate personally build or own a production embeddings-based retrieval system serving real users?"
      },
      {
        "id": "vector_db_prod",
        "q": "Did the candidate personally operate a vector DB or hybrid-search infrastructure in production (Pinecone/Weaviate/Qdrant/Milvus/OpenSearch/Elasticsearch/FAISS or similar)?"
      },
      {
        "id": "owns_eval_framework",
        "q": "Did the candidate build an evaluation system that measures RANKING or RETRIEVAL quality, using metrics like NDCG, MRR, MAP, recall@k, precision@k, or offline-to-online correlation? Answer NO if their 'experimentation framework' / A/B testing only measured generic product metrics (conversion, retention, engagement, churn) rather than ranking or retrieval quality."
      },
      {
        "id": "strong_python_prod",
        "q": "Is there evidence of strong production Python engineering, not just scripting/notebooks?"
      },
      {
        "id": "retrieval_ops_depth",
        "q": "Did the candidate handle retrieval operations specifically — embedding drift, index refresh, or retrieval-quality regression in production?"
      },
      {
        "id": "owns_ranking_prod",
        "q": "Did the candidate personally build or own a production ranking/recommendation system?"
      },
      {
        "id": "shipped_endtoend_at_scale",
        "q": "Did the candidate ship at least one end-to-end ranking, search, or recommendation system to real users at meaningful scale?"
      },
      {
        "id": "ltr_experience",
        "q": "Does the candidate have learning-to-rank experience (gradient-boosted or neural rankers)?"
      },
      {
        "id": "reranker_twostage",
        "q": "Has the candidate built a two-stage retrieve-then-rerank pipeline?"
      },
      {
        "id": "relevance_judgment_pipeline",
        "q": "Has the candidate built a relevance-judgment or labeling pipeline for a ranking/search system?"
      },
      {
        "id": "llm_finetuning",
        "q": "Does the candidate have hands-on LLM fine-tuning experience (LoRA/QLoRA/PEFT), not just API calling?"
      },
      {
        "id": "ab_testing_ml",
        "q": "Has the candidate run A/B tests for ML/ranking systems and interpreted the results?"
      },
      {
        "id": "distributed_systems_scale",
        "q": "Does the candidate have distributed-systems or large-scale inference-optimization background?"
      },
      {
        "id": "hrtech_or_marketplace_exp",
        "q": "Has the candidate worked on an HR-tech, recruiting-tech, jobs/hiring, or marketplace PRODUCT -- judged by the product/company domain, not the ML technique (e.g. job boards, talent platforms, gig or e-commerce marketplaces that connect two sides)? Answer NO for internal tooling, enterprise SaaS, or knowledge-base/document systems that are not marketplaces."
      },
      {
        "id": "external_validation",
        "q": "Does the history explicitly name a concrete external artifact produced by the candidate -- a published paper, a conference or meetup talk, a named open-source project or public repository, a patent, or a public blog post? Answer NO if none of these is explicitly named. Internal work is NOT an artifact: A/B tests, human relevance judgments, dashboards, and QA do not count."
      },
      {
        "id": "first_person_ownership",
        "q": "Did the candidate personally own the core ML/retrieval/ranking/modeling work -- i.e. they built the model/ranking/retrieval system itself? Answer NO when their hands-on work was the serving API, pipelines, infrastructure, or integration around someone else's model, or when they describe their own modeling as 'secondary' or say another team handled it -- even if it is phrased in the first person."
      },
      {
        "id": "primarily_adjacent",
        "q": "Was the candidate primarily adjacent to the ML work — built the pipelines/APIs/infra that served someone else's model, rather than the model/ranking itself?"
      },
      {
        "id": "observer_not_owner",
        "q": "Did the candidate lead/coordinate/contribute to the work without personally building it (leader/observer, not owner)?"
      },
      {
        "id": "manager_not_builder",
        "q": "Is the candidate described primarily as a manager whose team did the building, rather than an individual builder?"
      },
      {
        "id": "cv_dominant",
        "q": "Is the candidate's ML work primarily computer vision?"
      },
      {
        "id": "speech_dominant",
        "q": "Is the candidate's ML work primarily speech/audio?"
      },
      {
        "id": "robotics_dominant",
        "q": "Is the candidate's ML work primarily robotics/control?"
      },
      {
        "id": "nlp_ir_significant",
        "q": "Does the candidate have significant NLP or information-retrieval experience?"
      },
      {
        "id": "research_not_applied",
        "q": "Is the candidate's career purely research/academic (research-only roles or academic labs) WITHOUT any production deployment?"
      },
      {
        "id": "ic_role",
        "q": "Is the candidate currently an individual contributor who writes code, as opposed to a pure architecture/tech-lead role?"
      },
      {
        "id": "llm_api_wrapper_only",
        "q": "Is the candidate's AI experience primarily calling hosted LLM APIs / LangChain wrappers rather than building ML systems?"
      },
      {
        "id": "pre_llm_ml_production",
        "q": "Does the candidate have substantial pre-LLM-era ML production experience (understood retrieval/ranking before it was fashionable)?"
      },
      {
        "id": "is_hobbyist_or_self_learner",
        "q": "Does the candidate explicitly state their AI/ML experience is from self-learning, side projects, online courses, or otherwise NOT in a professional capacity?"
      },
      {
        "id": "built_recruiter_or_jd_matching",
        "q": "Is the candidate's hands-on work specifically in the HIRING/TALENT domain -- recruiter-facing candidate search, candidate-to-job or resume-to-JD matching, talent intelligence, or hiring/ATS ranking? Answer YES only when the description explicitly names recruiting, hiring, candidates, resumes/CVs, job-seekers, talent, or ATS. Answer NO for generic search, e-commerce or product recommendation, ads, content/news feeds, marketplace recsys, knowledge-base or document search, and support chatbots -- even when they mention 'matching', 'relevance', 'ranking', or 'recommendation'."
      },
      {
        "id": "scrappy_shipper",
        "q": "Does the history show a bias toward shipping pragmatically -- fast MVPs, 'working over perfect', iterating with real users -- rather than research polish or perfectionism?"
      }
    ],
    "candidates_for_eval_only": [
      {
        "id": "backend_integration_only",
        "q": "Did the candidate explicitly state their role was only integrating the model / observability / writing the APIs, and explicitly not the model itself?",
        "status": "HOLD — likely redundant with primarily_adjacent. Add only if the hard-case eval shows primarily_adjacent missing this case."
      }
    ]
  }
}