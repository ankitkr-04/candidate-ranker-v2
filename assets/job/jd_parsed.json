{
  "policy_version": "4.0",
  "$schema": "../schema/jd_schema.json",
  "job_id": "redrob_senior_ai_engineer_founding",
  "evaluator_contract": {
    "predicate": "leaf {flag:name} | {flag:name,negate} via {not:{flag}} | {metric:name,op:'<|<=|>|>=|==|!=',value:X} ; node {all:[...]} | {any:[...]} | {not:pred}",
    "multiplier_stage_types": {
      "lookup": "value = map[feature] else default",
      "curve": "bands sorted by 'at'; direction 'min' picks first band where feature>=at; 'max' picks first where feature<=at; at=null is default",
      "conditional": "first case whose 'when' predicate is true -> value; else default",
      "decay": "value = max(floor, base ** feature)",
      "composite_product": "product of member stages, then clamp"
    },
    "pipeline": "score = clamp(career_substance + skill_booster,0,1); for s in multipliers: score*=eval(s); for g in hard_gates: if eval(g.when): score*=g.multiplier. Job-agnostic data-quality penalties are applied separately by the integrity layer."
  },
  "scoring": {
    "uncertain_treatment": {
      "positive_flag_cannot_determine": "false",
      "disqualifier_flag_cannot_determine": "do_not_fire"
    },
    "tie_break": [
      "candidate_id asc"
    ],
    "sub_threshold_floor": {
      "substance": {
        "applied_ml_years": 1.0,
        "years_of_experience": 0.01
      },
      "categorical": {
        "current_title_bucket": {
          "ideal": 0.6,
          "strong_positive": 0.5,
          "moderate_positive": 0.4,
          "junior_ml": 0.3,
          "neutral_read_description": 0.2,
          "heavy_penalty": 0.05,
          "hard_sink": 0.0
        }
      },
      "headroom": 0.9
    }
  },
  "features": {
    "flags": {
      "slm": [
        "owns_retrieval_prod",
        "vector_db_prod",
        "owns_eval_framework",
        "strong_python_prod",
        "retrieval_ops_depth",
        "owns_ranking_prod",
        "shipped_endtoend_at_scale",
        "ltr_experience",
        "reranker_twostage",
        "relevance_judgment_pipeline",
        "llm_finetuning",
        "ab_testing_ml",
        "distributed_systems_scale",
        "hrtech_or_marketplace_exp",
        "external_validation",
        "first_person_ownership",
        "primarily_adjacent",
        "observer_not_owner",
        "manager_not_builder",
        "cv_dominant",
        "speech_dominant",
        "robotics_dominant",
        "nlp_ir_significant",
        "research_not_applied",
        "ic_role",
        "llm_api_wrapper_only",
        "pre_llm_ml_production",
        "is_hobbyist_or_self_learner",
        "built_recruiter_or_jd_matching",
        "scrappy_shipper"
      ],
      "deterministic": {
        "current_is_services": "current_company in lookups.company.it_services",
        "majority_career_services": "duration-weighted fraction of career at it_services companies > 0.5",
        "has_product_company": "any career company in lookups.company.product_set",
        "has_ai_native": "any career company in lookups.company.ai_native",
        "titles_escalating": "seniority rank strictly increasing across last 3 employers",
        "is_local": "normalized location in lookups.location.local_cities",
        "prefers_remote": "redrob_signals.preferred_work_mode == 'remote'",
        "open_to_work_flag": "redrob_signals.open_to_work_flag",
        "enterprise_lifer": "every career role at a 10001+ employer (>=2 roles). COMPUTED BUT NO LONGER SCORED: the JD never penalizes big/product-company tenure -- it only rejects consulting-only careers (handled by company_context + lifelong_services gate) and rewards scrappy shippers (shipper_bonus). Headcount 10001+ caught product-company veterans (Uber/Microsoft/Amazon), which is the JD's ideal candidate, not a risk. Retained like prefers_remote: harmless, unused.",
        "has_skill_assessment": "redrob_signals.skill_assessment_scores is non-empty; presence (not value) is a platform-engagement signal"
      }
    },
    "metrics": {
      "years_of_experience": "profile.years_of_experience",
      "applied_ml_years": "min(years_of_experience, sum(role.duration_months/12 * career_ml_credit.factor(role.title)))  [deterministic; no SLM lift]",
      "median_tenure_last_3_months": "median duration_months of last 3 employers",
      "current_role_duration_months": "duration_months of is_current role",
      "last_active_days": "reference_date - redrob_signals.last_active_date, in days",
      "recruiter_response_rate": "redrob_signals.recruiter_response_rate",
      "interview_completion_rate": "redrob_signals.interview_completion_rate",
      "saved_by_recruiters_30d": "redrob_signals.saved_by_recruiters_30d",
      "applications_submitted_30d": "redrob_signals.applications_submitted_30d",
      "notice_period_days": "redrob_signals.notice_period_days",
      "github_activity_score": "redrob_signals.github_activity_score",
      "career_substance": "computed by the career_substance block (available to later stages)",
      "num_qualifying_unevidenced_skills": "count of skill_booster.qualifying skills whose competence flag is not already true"
    },
    "categoricals": {
      "location_relocation_bucket": {
        "derive": "from normalized location + country + willing_to_relocate",
        "values": [
          "local",
          "tier1_relocating",
          "tier1_not_relocating",
          "other_india_relocating",
          "other_india_not_relocating",
          "outside_relocating",
          "outside_not_relocating"
        ]
      },
      "current_title_bucket": {
        "derive": "current_title matched against lookups.title.current_title_buckets",
        "values": [
          "hard_sink",
          "heavy_penalty",
          "neutral_read_description",
          "junior_ml",
          "moderate_positive",
          "strong_positive",
          "ideal"
        ]
      },
      "verification_state": {
        "derive": "verified_email + verified_phone",
        "values": [
          "both",
          "one",
          "neither"
        ]
      }
    }
  },
  "career_substance": {
    "additive": {
      "owns_retrieval_prod": 0.22,
      "owns_eval_framework": 0.18,
      "owns_ranking_prod": 0.14,
      "vector_db_prod": 0.10,
      "retrieval_ops_depth": 0.08,
      "shipped_endtoend_at_scale": 0.06,
      "strong_python_prod": 0.04,
      "ab_testing_ml": 0.03
    },
    "bonus": {
      "knee": 0.5,
      "additive": {
        "ltr_experience": 0.06,
        "reranker_twostage": 0.05,
        "relevance_judgment_pipeline": 0.05,
        "llm_finetuning": 0.04,
        "distributed_systems_scale": 0.03,
        "hrtech_or_marketplace_exp": 0.03,
        "external_validation": 0.02
      }
    },
    "requires": {
      "owns_eval_framework": {
        "any": [ { "flag": "owns_ranking_prod" }, { "flag": "owns_retrieval_prod" } ]
      },
      "retrieval_ops_depth": {
        "any": [ { "flag": "owns_ranking_prod" }, { "flag": "owns_retrieval_prod" } ]
      },
      "shipped_endtoend_at_scale": {
        "any": [ { "flag": "owns_ranking_prod" }, { "flag": "owns_retrieval_prod" } ]
      },
      "ltr_experience": {
        "any": [ { "flag": "owns_ranking_prod" }, { "flag": "owns_retrieval_prod" } ]
      },
      "reranker_twostage": {
        "any": [ { "flag": "owns_ranking_prod" }, { "flag": "owns_retrieval_prod" } ]
      },
      "relevance_judgment_pipeline": {
        "any": [ { "flag": "owns_ranking_prod" }, { "flag": "owns_retrieval_prod" } ]
      }
    },
    "gates": [
      {
        "when": {
          "flag": "primarily_adjacent"
        },
        "multiplier": 0.55
      },
      {
        "when": {
          "flag": "observer_not_owner"
        },
        "multiplier": 0.65
      },
      {
        "when": {
          "flag": "manager_not_builder"
        },
        "multiplier": 0.35
      },
      {
        "when": {
          "flag": "is_hobbyist_or_self_learner"
        },
        "multiplier": 0.5
      },
      {
        "when": {
          "all": [
            {
              "any": [
                {
                  "flag": "cv_dominant"
                },
                {
                  "flag": "speech_dominant"
                },
                {
                  "flag": "robotics_dominant"
                }
              ]
            },
            {
              "not": {
                "flag": "nlp_ir_significant"
              }
            }
          ]
        },
        "multiplier": 0.25,
        "id": "domain_gate"
      }
    ],
    "clamp": [
      0.0,
      1.0
    ]
  },
  "skill_booster": {
    "when": {
      "metric": "career_substance",
      "op": ">=",
      "value": 0.6
    },
    "per_skill": 0.02,
    "max": 0.06,
    "count_feature": "num_qualifying_unevidenced_skills",
    "credit_rule": "count num_qualifying_unevidenced_skills, bonus = min(max, per_skill * count). disqualified skills give zero (not a penalty).",
    "qualifying": [
      "learning to rank",
      "bm25",
      "pgvector",
      "pinecone",
      "weaviate",
      "milvus",
      "qdrant",
      "haystack",
      "opensearch",
      "elasticsearch",
      "lora",
      "qlora",
      "peft",
      "llamaindex",
      "ranking systems",
      "search infrastructure",
      "indexing algorithms",
      "text encoders",
      "information retrieval systems",
      "search backend"
    ],
    "disqualified": [
      "langchain",
      "rag",
      "llms",
      "embeddings",
      "vector search",
      "semantic search",
      "prompt engineering",
      "sentence transformers",
      "hugging face transformers",
      "recommendation systems",
      "information retrieval",
      "mlops",
      "data science",
      "machine learning",
      "nlp",
      "deep learning",
      "ai"
    ]
  },
  "multipliers": [
    {
      "id": "current_title_congruence",
      "type": "lookup",
      "feature": "current_title_bucket",
      "map": {
        "hard_sink": 0.06,
        "heavy_penalty": 0.25,
        "neutral_read_description": 0.55,
        "junior_ml": 0.65,
        "moderate_positive": 0.8,
        "strong_positive": 0.95,
        "ideal": 1.0
      },
      "default": 0.55
    },
    {
      "id": "company_context",
      "type": "conditional",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "all": [
              {
                "flag": "current_is_services"
              },
              {
                "flag": "has_product_company"
              }
            ]
          },
          "value": 1.0
        },
        {
          "when": {
            "all": [
              {
                "flag": "current_is_services"
              },
              {
                "not": {
                  "flag": "has_product_company"
                }
              }
            ]
          },
          "value": 0.85
        },
        {
          "when": {
            "all": [
              {
                "flag": "majority_career_services"
              },
              {
                "flag": "has_product_company"
              }
            ]
          },
          "value": 0.9
        }
      ]
    },
    {
      "id": "experience_band",
      "type": "curve",
      "feature": "years_of_experience",
      "direction": "min",
      "bands": [
        {
          "at": 14,
          "value": 0.95
        },
        {
          "at": 11,
          "value": 0.98
        },
        {
          "at": 9,
          "value": 1.0
        },
        {
          "at": 6,
          "value": 1.0
        },
        {
          "at": 5,
          "value": 0.98
        },
        {
          "at": 4,
          "value": 0.95
        },
        {
          "at": 3,
          "value": 0.9
        },
        {
          "at": 0,
          "value": 0.85
        }
      ]
    },
    {
      "id": "applied_ml_years",
      "type": "curve",
      "feature": "applied_ml_years",
      "direction": "min",
      "bands": [
        {
          "at": 4.0,
          "value": 1.0
        },
        {
          "at": 2.5,
          "value": 0.92
        },
        {
          "at": 1.0,
          "value": 0.8
        },
        {
          "at": 0.0,
          "value": 0.6
        }
      ]
    },
    {
      "id": "location",
      "type": "lookup",
      "feature": "location_relocation_bucket",
      "map": {
        "local": 1.0,
        "commutable_relocating": 0.97,
        "commutable_not_relocating": 0.9,
        "tier1_relocating": 0.95,
        "tier1_not_relocating": 0.6,
        "other_india_relocating": 0.88,
        "other_india_not_relocating": 0.55,
        "outside_relocating": 0.15,
        "outside_not_relocating": 0.04
      },
      "default": 0.4
    },
    {
      "id": "verification",
      "type": "lookup",
      "feature": "verification_state",
      "map": {
        "both": 1.0,
        "one": 0.98,
        "neither": 0.96
      },
      "default": 0.96
    },
    {
      "id": "behavioral",
      "type": "composite_product",
      "clamp": [
        0.05,
        1.05
      ],
      "members": [
        {
          "id": "last_active_recency",
          "type": "curve",
          "feature": "last_active_days",
          "direction": "max",
          "bands": [
            {
              "at": 30,
              "value": 1.0
            },
            {
              "at": 90,
              "value": 0.9
            },
            {
              "at": 180,
              "value": 0.7
            },
            {
              "at": null,
              "value": 0.45
            }
          ]
        },
        {
          "id": "recruiter_response",
          "type": "curve",
          "feature": "recruiter_response_rate",
          "direction": "min",
          "bands": [
            {
              "at": 0.6,
              "value": 1.0
            },
            {
              "at": 0.45,
              "value": 0.92
            },
            {
              "at": 0.25,
              "value": 0.78
            },
            {
              "at": 0.0,
              "value": 0.45
            }
          ]
        },
        {
          "id": "open_to_work",
          "type": "conditional",
          "default": 1.0,
          "cases": [
            {
              "when": {
                "flag": "open_to_work_flag"
              },
              "value": 1.02
            }
          ]
        },
        {
          "id": "interview_completion",
          "type": "curve",
          "feature": "interview_completion_rate",
          "direction": "min",
          "bands": [
            {
              "at": 0.9,
              "value": 1.0
            },
            {
              "at": 0.5,
              "value": 0.96
            },
            {
              "at": 0.0,
              "value": 0.92
            }
          ]
        },
        {
          "id": "saved_by_recruiters",
          "type": "curve",
          "feature": "saved_by_recruiters_30d",
          "direction": "min",
          "bands": [
            {
              "at": 5,
              "value": 1.05
            },
            {
              "at": 1,
              "value": 1.02
            },
            {
              "at": 0,
              "value": 1.0
            }
          ]
        },
        {
          "id": "applications_recent",
          "type": "curve",
          "feature": "applications_submitted_30d",
          "direction": "min",
          "bands": [
            {
              "at": 1,
              "value": 1.0
            },
            {
              "at": 0,
              "value": 0.97
            }
          ]
        },
        {
          "id": "assessment_engagement",
          "type": "conditional",
          "default": 1.0,
          "cases": [
            {
              "when": {
                "flag": "has_skill_assessment"
              },
              "value": 1.03
            }
          ]
        }
      ]
    },
    {
      "id": "notice_period",
      "type": "curve",
      "feature": "notice_period_days",
      "direction": "max",
      "bands": [
        {
          "at": 30,
          "value": 1.0
        },
        {
          "at": 45,
          "value": 0.95
        },
        {
          "at": 60,
          "value": 0.90
        },
        {
          "at": 75,
          "value": 0.85
        },
        {
          "at": 90,
          "value": 0.80
        },
        {
          "at": 120,
          "value": 0.65
        },
        {
          "at": null,
          "value": 0.50
        }
      ]
    },
    {
      "id": "title_chaser",
      "type": "conditional",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "all": [
              {
                "metric": "median_tenure_last_3_months",
                "op": "<",
                "value": 18
              },
              {
                "metric": "current_role_duration_months",
                "op": "<",
                "value": 24
              },
              {
                "flag": "titles_escalating"
              }
            ]
          },
          "value": 0.33
        }
      ]
    },
    {
      "id": "github_bonus",
      "type": "conditional",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "all": [
              {
                "metric": "career_substance",
                "op": ">=",
                "value": 0.6
              },
              {
                "metric": "github_activity_score",
                "op": ">",
                "value": 60
              }
            ]
          },
          "value": 1.03
        }
      ]
    },
    {
      "id": "domain_mandate_bonus",
      "type": "conditional",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "all": [
              {
                "flag": "hrtech_or_marketplace_exp"
              },
              {
                "flag": "first_person_ownership"
              },
              {
                "any": [
                  {
                    "flag": "owns_retrieval_prod"
                  },
                  {
                    "flag": "owns_ranking_prod"
                  }
                ]
              },
              {
                "flag": "observer_not_owner",
                "negate": true
              }
            ]
          },
          "value": 1.05
        }
      ]
    },
    {
      "id": "narrow_domain_bonus",
      "type": "conditional",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "flag": "built_recruiter_or_jd_matching"
          },
          "value": 1.08
        }
      ]
    },
    {
      "id": "shipper_bonus",
      "type": "conditional",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "flag": "scrappy_shipper"
          },
          "value": 1.03
        }
      ]
    }
  ],
  "hard_gates": [
    {
      "id": "research_no_production",
      "when": {
        "flag": "research_not_applied"
      },
      "multiplier": 0.03
    },
    {
      "id": "lifelong_services",
      "when": {
        "all": [
          {
            "flag": "majority_career_services"
          },
          {
            "not": {
              "flag": "has_product_company"
            }
          }
        ]
      },
      "multiplier": 0.12
    },
    {
      "id": "langchain_recent_only",
      "when": {
        "all": [
          {
            "flag": "llm_api_wrapper_only"
          },
          {
            "not": {
              "flag": "pre_llm_ml_production"
            }
          }
        ]
      },
      "multiplier": 0.2
    },
    {
      "id": "stale_coding_senior",
      "when": {
        "all": [
          {
            "metric": "current_role_duration_months",
            "op": ">=",
            "value": 18
          },
          {
            "any": [
              {
                "flag": "manager_not_builder"
              },
              {
                "not": {
                  "flag": "ic_role"
                }
              }
            ]
          }
        ]
      },
      "multiplier": 0.3
    }
  ],
  "derived_flags": [
    {
      "target": "strong_python_prod",
      "preserve_as": "strong_python_slm",
      "when": {
        "any": [
          { "flag": "strong_python_prod" },
          { "flag": "owns_retrieval_prod" },
          { "flag": "owns_ranking_prod" },
          { "flag": "owns_eval_framework" },
          { "flag": "shipped_endtoend_at_scale" }
        ]
      }
    }
  ],
