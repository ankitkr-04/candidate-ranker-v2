{
  "$schema": "../schema/penalties_schema.json",
  "version": "1.0",
 
  "description": "Job-agnostic profile-integrity penalties. Each flags data that is implausible for any genuine candidate (inconsistent dates, a skill used longer than the person has worked or longer than the tool has existed, a senior title dated before the first degree finished). Applied as small multiplicative penalties that compound into a ranking gradient -- no single hard cut.",
  "tool_eras": {
    "prompt engineering": 2020,
    "rag": 2020,
    "langchain": 2022,
    "llamaindex": 2022,
    "chatgpt": 2022,
    "llms": 2019,
    "llm fine-tuning": 2021,
    "lora": 2021,
    "qlora": 2023,
    "peft": 2022,
    "vector database": 2019,
    "vector search": 2019,
    "weaviate": 2019,
    "pinecone": 2019,
    "qdrant": 2021,
    "milvus": 2019,
    "sentence transformers": 2019,
    "semantic search": 2019,
    "hugging face transformers": 2019,
    "faiss": 2017,
    "mlflow": 2018,
    "haystack": 2019,
    "bentoml": 2019,
    "kubeflow": 2017,
    "diffusion models": 2021,
    "pgvector": 2021,
    "opensearch": 2021
  },
  "company_founding": {
    "TCS": 1968,
    "Wipro": 1945,
    "Infosys": 1981,
    "HCL": 1976,
    "Capgemini": 1967,
    "Accenture": 1989,
    "Cognizant": 1994,
    "Tech Mahindra": 1986,
    "Mindtree": 1999,
    "Mphasis": 1998,
    "Genpact AI": 1997,
    "Apple": 1976,
    "Microsoft": 1975,
    "Google": 1998,
    "Amazon": 1994,
    "Meta": 2004,
    "Netflix": 1997,
    "Adobe": 1982,
    "Salesforce": 1999,
    "LinkedIn": 2003,
    "Uber": 2009,
    "Flipkart": 2007,
    "InMobi": 2007,
    "Zoho": 1996,
    "Dream11": 2008,
    "PolicyBazaar": 2008,
    "Zomato": 2008,
    "Ola": 2010,
    "Paytm": 2010,
    "Freshworks": 2010,
    "BYJU'S": 2011,
    "Vedantu": 2011,
    "Nykaa": 2012,
    "Haptik": 2013,
    "Mad Street Den": 2013,
    "Swiggy": 2014,
    "Razorpay": 2014,
    "Meesho": 2015,
    "PhonePe": 2015,
    "Unacademy": 2015,
    "PharmEasy": 2015,
    "upGrad": 2015,
    "Wysa": 2015,
    "Locobuzz": 2015,
    "Yellow.ai": 2016,
    "Verloop.io": 2016,
    "Niramai": 2016,
    "Aganitha": 2016,
    "Observe.AI": 2017,
    "Saarthi.ai": 2017,
    "CRED": 2018,
    "Glance": 2019,
    "Rephrase.ai": 2019,
    "Sarvam AI": 2023,
    "Krutrim": 2023
  },
  "params": {
    "overrun_slack_months": 18.0,
    "seniority_min_rank": 3,
    "experience_span_buffer_years": 5.0,
    "anachronism_buffer_months": 3.0,
    "anachronism_grace_years": 0.75,
    "anomaly_buffer_months": 12.0
  },
  "seniority_ladder": {
    "default": 2,
    "tiers": [
      { "keywords": ["intern"], "rank": 0 },
      { "keywords": ["junior", "jr", "associate", "trainee"], "rank": 1 },
      { "keywords": ["senior", "sr", "lead", "principal", "staff"], "rank": 3 },
      { "keywords": ["manager", "head", "director", "vp", "chief", "cto"], "rank": 4 }
    ]
  },
  "features": {
    "flags": [
      "end_before_start",
      "career_months_overrun",
      "role_months_overrun",
      "current_role_date_conflict",
      "senior_title_pre_graduation",
      "experience_exceeds_career_span"
    ],
    "metrics": [
      "num_education_overlaps",
      "num_skill_anomalies",
      "num_proficiency_anomalies",
      "num_skill_anachronisms",
      "skill_anachronism_years",
      "years_predating_company"
    ]
  },
  "penalties": [
    {
      "id": "end_before_start_penalty",
      "type": "conditional",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "flag": "end_before_start"
          },
          "value": 0.4
        }
      ]
    },
    {
      "id": "career_months_overrun_penalty",
      "type": "conditional",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "flag": "career_months_overrun"
          },
          "value": 0.9
        }
      ]
    },
    {
      "id": "role_months_overrun_penalty",
      "type": "conditional",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "flag": "role_months_overrun"
          },
          "value": 0.85
        }
      ]
    },
    {
      "id": "current_role_date_conflict_penalty",
      "type": "conditional",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "flag": "current_role_date_conflict"
          },
          "value": 0.85
        }
      ]
    },
    {
      "id": "experience_span_penalty",
      "type": "conditional",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "flag": "experience_exceeds_career_span"
          },
          "value": 0.1
        }
      ]
    },
    {
      "id": "education_overlap_penalty",
      "type": "decay",
      "feature": "num_education_overlaps",
      "base": 0.98,
      "floor": 0.92
    },
    {
      "id": "skill_anomaly_penalty",
      "type": "decay",
      "feature": "num_skill_anomalies",
      "base": 0.985,
      "floor": 0.93
    },
    {
      "id": "proficiency_anomaly_penalty",
      "type": "decay",
      "feature": "num_proficiency_anomalies",
      "base": 0.55,
      "floor": 0.12
    },
    {
      "id": "skill_anachronism_magnitude_penalty",
      "type": "decay",
      "feature": "skill_anachronism_years",
      "base": 0.85,
      "floor": 0.2
    },
    {
      "id": "skill_anachronism_count_penalty",
      "type": "curve",
      "feature": "num_skill_anachronisms",
      "direction": "max",
      "bands": [
        { "at": 1, "value": 1.0 },
        { "at": 2, "value": 0.82 },
        { "at": 3, "value": 0.55 },
        { "at": 4, "value": 0.35 },
        { "value": 0.2 }
      ]
    },
    {
      "id": "company_predates_penalty",
      "type": "curve",
      "feature": "years_predating_company",
      "direction": "max",
      "bands": [
        { "at": 0, "value": 1.0 },
        { "at": 1, "value": 0.97 },
        { "at": 2, "value": 0.60 },
        { "at": 3, "value": 0.35 },
        { "at": 4, "value": 0.20 },
        { "value": 0.18 }
      ]
    },
    {
      "id": "seniority_before_graduation_penalty",
      "type": "conditional",
      "default": 1.0,
      "cases": [
        {
          "when": {
            "flag": "senior_title_pre_graduation"
          },
          "value": 0.85
        }
      ]
    }
  ]
}