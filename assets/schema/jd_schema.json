{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JDParsed",
  "description": "Job-specific scoring policy applied to candidate profiles.",
  "type": "object",
  "required": [
    "policy_version", "job_id", "evaluator_contract", "scoring",
    "features", "career_substance", "skill_booster", "multipliers",
    "hard_gates", "lookups", "slm_questions"
  ],
  "properties": {
    "policy_version": { "type": "string" },
    "job_id": {
      "type": "string",
      "description": "Unique identifier for this JD eval config, e.g. 'acme_senior_ml_engineer'"
    },
    "evaluator_contract": {
      "type": "object",
      "description": "Documentation block. Not validated at runtime. Describes predicate syntax, stage types, pipeline formula.",
      "properties": {
        "predicate": { "type": "string" },
        "multiplier_stage_types": { "type": "object" },
        "pipeline": { "type": "string" }
      }
    },
    "scoring": {
      "type": "object",
      "required": ["uncertain_treatment", "tie_break"],
      "properties": {
        "uncertain_treatment": {
          "type": "object",
          "description": "How to handle SLM flags when evidence is ambiguous.",
          "properties": {
            "positive_flag_cannot_determine": {
              "type": "string",
              "enum": ["true", "false", "do_not_fire"],
              "description": "Default treatment for positive SLM flags when undetermined"
            },
            "disqualifier_flag_cannot_determine": {
              "type": "string",
              "enum": ["true", "false", "do_not_fire"],
              "description": "Default treatment for disqualifier flags when undetermined"
            }
          }
        },
        "tie_break": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Ordered sort expressions for equal-score candidates, e.g. ['career_substance desc', 'candidate_id asc']"
        }
      }
    },
    "features": {
      "type": "object",
      "required": ["flags", "metrics", "categoricals"],
      "properties": {
        "flags": {
          "type": "object",
          "required": ["slm", "deterministic"],
          "properties": {
            "slm": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Boolean flags extracted by SLM from career history. Each id must appear in slm_questions[].id."
            },
            "deterministic": {
              "type": "object",
              "additionalProperties": { "type": "string" },
              "description": "flag_name -> derivation_expression. Computed without SLM (rule-based)."
            }
          }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "metric_name -> derivation_expression or source path."
        },
        "categoricals": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["derive", "values"],
            "properties": {
              "derive": { "type": "string" },
              "values": {
                "type": "array",
                "items": { "type": "string" },
                "description": "All possible enum values. Must match lookup map keys if referenced."
              }
            }
          }
        }
      }
    },
    "career_substance": {
      "type": "object",
      "required": ["additive", "gates", "clamp"],
      "description": "Computes a [0,1] substance score from SLM flags, then clamps.",
      "properties": {
        "additive": {
          "type": "object",
          "additionalProperties": { "type": "number" },
          "description": "slm_flag -> additive weight. Weights typically sum to ~1.0 but can exceed it before clamp."
        },
        "gates": {
          "type": "array",
          "description": "Multiplicative gates applied sequentially to the additive sum. Used for domain/ownership adjustments.",
          "items": {
            "type": "object",
            "required": ["when", "multiplier"],
            "properties": {
              "id": { "type": "string" },
              "when": { "$ref": "#/definitions/Predicate" },
              "multiplier": { "type": "number" }
            }
          }
        },
        "clamp": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2,
          "description": "[min, max] clamp applied after additive + gates. Typically [0.0, 1.0]."
        }
      }
    },
    "skill_booster": {
      "type": "object",
      "required": ["when", "per_skill", "max", "credit_rule", "qualifying", "disqualified"],
      "description": "Small additive bonus for listed skills not yet evidenced by SLM flags. Only active above a career_substance threshold.",
      "properties": {
        "when": {
          "$ref": "#/definitions/Predicate",
          "description": "Condition for booster to activate, e.g. career_substance >= 0.6"
        },
        "per_skill": {
          "type": "number",
          "description": "Bonus per qualifying unevidenced skill"
        },
        "max": {
          "type": "number",
          "description": "Cap on total booster added"
        },
        "credit_rule": { "type": "string" },
        "qualifying": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Skills that earn the per_skill bonus if listed and not already evidenced by a true SLM flag"
        },
        "disqualified": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Skills excluded from the booster (too generic). No penalty — just zero credit."
        }
      }
    },
    "multipliers": {
      "type": "array",
      "description": "Ordered multiplier stages. score = clamp(career_substance + skill_booster, 0, 1); for s in multipliers: score *= eval(s).",
      "items": { "$ref": "#/definitions/Stage" }
    },
    "hard_gates": {
      "type": "array",
      "description": "Applied after multipliers. Soft disqualifiers — very low multipliers (typically 0.03–0.3) for archetypal mismatches.",
      "items": {
        "type": "object",
        "required": ["id", "when", "multiplier"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "when": { "$ref": "#/definitions/Predicate" },
          "multiplier": { "type": "number" }
        }
      }
    },
    "lookups": {
      "type": "object",
      "description": "Static reference data used by deterministic flags and multiplier maps.",
      "properties": {
        "company": {
          "type": "object",
          "description": "Named company lists. A list value may contain either company name strings or references to other list keys (for set union).",
          "properties": {
            "it_services": { "type": "array", "items": { "type": "string" } },
            "fictional_neutral": { "type": "array", "items": { "type": "string" } },
            "product_india": { "type": "array", "items": { "type": "string" } },
            "ai_native": { "type": "array", "items": { "type": "string" } },
            "tier_0": { "type": "array", "items": { "type": "string" } },
            "product_set": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Keys referencing other company sub-lists; acts as a union."
            }
          },
          "additionalProperties": { "type": "array", "items": { "type": "string" } }
        },
        "location": {
          "type": "object",
          "additionalProperties": { "type": "array", "items": { "type": "string" } }
        },
        "title": {
          "type": "object",
          "properties": {
            "current_title_buckets": {
              "type": "object",
              "description": "bucket_name -> [title strings]. Bucket names must exactly match values defined in features.categoricals.current_title_bucket.",
              "additionalProperties": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "career_ml_credit": {
          "type": "object",
          "description": "credit_tier -> { factor, titles }. Used to compute applied_ml_years metric.",
          "additionalProperties": {
            "type": "object",
            "required": ["factor", "titles"],
            "additionalProperties": false,
            "properties": {
              "factor": {
                "type": "number",
                "minimum": 0.0,
                "maximum": 1.0,
                "description": "Duration multiplier: 0.0 = no ML credit, 0.5 = partial, 1.0 = full"
              },
              "titles": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "slm_questions": {
      "type": "object",
      "required": ["input_scope", "extraction_order", "ask"],
      "properties": {
        "input_scope": {
          "type": "string",
          "description": "What profile fields are visible to the SLM when answering questions"
        },
        "extraction_order": {
          "type": "string",
          "description": "Instruction on output ordering / structure for the SLM"
        },
        "ask": {
          "type": "array",
          "description": "Questions sent to SLM. Every id here must appear in features.flags.slm (or be type=string for open-ended).",
          "items": {
            "type": "object",
            "required": ["id", "q"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "type": {
                "type": "string",
                "description": "Omit for boolean (default). Use 'string' for free-text output fields like subject_of_primary_work."
              },
              "q": { "type": "string" }
            }
          }
        },
        "candidates_for_eval_only": {
          "type": "array",
          "description": "Candidate questions not yet promoted to production. status explains hold rationale.",
          "items": {
            "type": "object",
            "required": ["id", "q", "status"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "q": { "type": "string" },
              "status": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "Predicate": {
      "description": "Boolean condition over flags and/or metrics.",
      "oneOf": [
        {
          "title": "FlagCheck",
          "type": "object",
          "required": ["flag"],
          "additionalProperties": false,
          "properties": {
            "flag": { "type": "string" },
            "negate": { "type": "boolean" }
          }
        },
        {
          "title": "MetricCheck",
          "type": "object",
          "required": ["metric", "op", "value"],
          "additionalProperties": false,
          "properties": {
            "metric": { "type": "string" },
            "op": { "type": "string", "enum": ["<", "<=", ">", ">=", "==", "!="] },
            "value": { "type": "number" }
          }
        },
        {
          "title": "All",
          "type": "object",
          "required": ["all"],
          "additionalProperties": false,
          "properties": {
            "all": { "type": "array", "items": { "$ref": "#/definitions/Predicate" }, "minItems": 1 }
          }
        },
        {
          "title": "Any",
          "type": "object",
          "required": ["any"],
          "additionalProperties": false,
          "properties": {
            "any": { "type": "array", "items": { "$ref": "#/definitions/Predicate" }, "minItems": 1 }
          }
        },
        {
          "title": "Not",
          "type": "object",
          "required": ["not"],
          "additionalProperties": false,
          "properties": {
            "not": { "$ref": "#/definitions/Predicate" }
          }
        }
      ]
    },
    "ConditionalCase": {
      "type": "object",
      "required": ["when", "value"],
      "additionalProperties": false,
      "properties": {
        "when": { "$ref": "#/definitions/Predicate" },
        "value": { "type": "number" }
      }
    },
    "Band": {
      "type": "object",
      "required": ["value"],
      "additionalProperties": false,
      "properties": {
        "at": {
          "description": "Threshold for this band. null = catch-all default.",
          "oneOf": [{ "type": "number" }, { "type": "null" }]
        },
        "value": { "type": "number" }
      }
    },
    "Stage": {
      "description": "A single scoring stage returning a numeric multiplier.",
      "oneOf": [
        {
          "title": "ConditionalStage",
          "description": "First case whose predicate is true -> value; else default.",
          "type": "object",
          "required": ["id", "type", "default", "cases"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string" },
            "type": { "const": "conditional" },
            "default": { "type": "number" },
            "cases": { "type": "array", "items": { "$ref": "#/definitions/ConditionalCase" } }
          }
        },
        {
          "title": "DecayStage",
          "description": "value = max(floor, base ** feature). Used for count-based penalties.",
          "type": "object",
          "required": ["id", "type", "feature", "base", "floor"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string" },
            "type": { "const": "decay" },
            "feature": { "type": "string" },
            "base": { "type": "number", "description": "< 1.0; each unit multiplies score by base" },
            "floor": { "type": "number", "description": "Minimum multiplier regardless of count" }
          }
        },
        {
          "title": "LookupStage",
          "description": "value = map[feature] else default.",
          "type": "object",
          "required": ["id", "type", "feature", "map", "default"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string" },
            "type": { "const": "lookup" },
            "feature": { "type": "string" },
            "map": { "type": "object", "additionalProperties": { "type": "number" } },
            "default": { "type": "number" }
          }
        },
        {
          "title": "CurveStage",
          "description": "Step function over sorted bands. direction=min: first band where feature>=at. direction=max: first band where feature<=at. at=null is catch-all.",
          "type": "object",
          "required": ["id", "type", "feature", "direction", "bands"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string" },
            "type": { "const": "curve" },
            "feature": { "type": "string" },
            "direction": { "type": "string", "enum": ["min", "max"] },
            "bands": { "type": "array", "items": { "$ref": "#/definitions/Band" }, "minItems": 1 }
          }
        },
        {
          "title": "CompositeProductStage",
          "description": "Product of member stages, then clamped.",
          "type": "object",
          "required": ["id", "type", "members"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string" },
            "type": { "const": "composite_product" },
            "clamp": {
              "type": "array",
              "items": { "type": "number" },
              "minItems": 2,
              "maxItems": 2
            },
            "members": { "type": "array", "items": { "$ref": "#/definitions/Stage" }, "minItems": 1 }
          }
        }
      ]
    }
  }
}